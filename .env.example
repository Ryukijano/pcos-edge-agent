# PCOS Configuration — copy to .env and adjust

# Broker
PCOS_BROKER_HOST=0.0.0.0
PCOS_BROKER_PORT=8000
PCOS_BROKER_LOG_LEVEL=info

# CORS (JSON array; do not use ["*"] in production)
PCOS_CORS_ORIGINS=["http://localhost:8000","http://localhost:7860"]

# PiecesOS
PCOS_PIECESOS_HOST=localhost
PCOS_PIECESOS_PORT=39300
PCOS_PIECESOS_ENABLED=true

# Bridge auth (required for public deployments)
PCOS_BRIDGE_AUTH_TOKEN=
PCOS_BRIDGE_AUTH_REQUIRED=false

# Latency budgets (ms)
PCOS_LATENCY_TARGET_ROUTE_MS=50
PCOS_LATENCY_TARGET_EXECUTE_MS=500
PCOS_LATENCY_TARGET_CHROME_MS=200
PCOS_LATENCY_TARGET_ANDROID_MS=1000
PCOS_LATENCY_TARGET_CLOUD_MS=3000

# Logging
PCOS_LOG_LEVEL=INFO
PCOS_LOG_JSON=true
PCOS_LOG_REQUEST_BODIES=false

# SQLite (empty = default data/pcos_metrics.db)
PCOS_DB_PATH=
